generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guild {
  id                 String                @id
  name               String?
  botName            String                @default("Хори")
  preferredLanguage  String                @default("ru")
  roughnessLevel     Int                   @default(2)
  sarcasmLevel       Int                   @default(2)
  roastLevel         Int                   @default(2)
  interjectTendency  Int                   @default(1)
  replyLength        String                @default("short")
  preferredStyle     String                @default("коротко, сухо, по делу")
  forbiddenWords     String[]              @default([])
  forbiddenTopics    String[]              @default([])
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  channelConfigs     ChannelConfig[]
  userStats          UserStats[]
  userProfiles       UserProfile[]
  relationshipProfiles RelationshipProfile[]
  messages           Message[]
  channelSummaries   ChannelSummary[]
  serverMemories     ServerMemory[]
  userMemoryNotes    UserMemoryNote[]
  botEventLogs       BotEventLog[]
  interjectionLogs   InterjectionLog[]
  moderatorPreferences ModeratorPreference[]
  channelStats       ChannelStats[]
  userDailyAggregates UserDailyAggregate[]
  channelDailyAggregates ChannelDailyAggregate[]
}

model ChannelConfig {
  id                String   @id @default(cuid())
  guildId           String
  channelId         String
  channelName       String?
  allowBotReplies   Boolean  @default(true)
  allowInterjections Boolean @default(false)
  isMuted           Boolean  @default(false)
  topicInterestTags String[] @default([])
  responseLengthOverride String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  guild             Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId])
  @@index([guildId])
}

model User {
  id               String                @id
  username         String?
  globalName       String?
  isBot            Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  messages         Message[]
  userStats        UserStats[]
  userProfiles     UserProfile[]
  relationshipTargets RelationshipProfile[] @relation("RelationshipTarget")
  relationshipUpdates RelationshipProfile[] @relation("RelationshipUpdatedBy")
  userMemoryNotes  UserMemoryNote[]      @relation("UserMemoryTarget")
  userDailyAggregates UserDailyAggregate[]
}

model UserStats {
  id                     String   @id @default(cuid())
  guildId                String
  userId                 String
  totalMessages          Int      @default(0)
  totalReplies           Int      @default(0)
  totalMentions          Int      @default(0)
  avgMessageLength       Float    @default(0)
  activeHoursHistogram   Json?
  topChannelsSnapshot    Json?
  conversationStarterCount Int    @default(0)
  updatedAt              DateTime @updatedAt
  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
}

model UserProfile {
  id               String   @id @default(cuid())
  userId           String
  guildId          String
  summaryShort     String
  styleTags        String[] @default([])
  topicTags        String[] @default([])
  confidenceScore  Float    @default(0)
  sourceWindowSize Int      @default(0)
  lastProfiledAt   DateTime?
  isEligible       Boolean  @default(false)
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
}

model RelationshipProfile {
  id               String   @id @default(cuid())
  userId           String
  guildId          String
  toneBias         String   @default("neutral")
  roastLevel       Int      @default(0)
  praiseBias       Int      @default(0)
  interruptPriority Int     @default(0)
  doNotMock        Boolean  @default(false)
  doNotInitiate    Boolean  @default(false)
  protectedTopics  String[] @default([])
  updatedBy        String?
  updatedAt        DateTime @updatedAt
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user             User     @relation("RelationshipTarget", fields: [userId], references: [id], onDelete: Cascade)
  updatedByUser    User?    @relation("RelationshipUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([guildId, userId])
}

model Message {
  id               String    @id
  guildId          String
  channelId        String
  userId           String
  content          String    @db.Text
  createdAt        DateTime
  replyToMessageId String?
  mentionCount     Int       @default(0)
  charCount        Int       @default(0)
  tokenEstimate    Int       @default(0)
  flags            Json?
  threadId         String?
  vectorizedAt     DateTime?
  guild            Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyToMessage   Message?  @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          Message[] @relation("MessageReplies")
  embedding        MessageEmbedding?

  @@index([guildId, channelId, createdAt])
  @@index([guildId, userId, createdAt])
}

model MessageEmbedding {
  id         String                @id @default(cuid())
  messageId  String                @unique
  guildId    String
  channelId  String
  embedding  Unsupported("vector")?
  dimensions Int
  createdAt  DateTime              @default(now())
  message    Message               @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId])
}

model ChannelSummary {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  rangeStart  DateTime
  rangeEnd    DateTime
  summaryShort String
  summaryLong String   @db.Text
  topicTags   String[] @default([])
  notableUsers String[] @default([])
  createdAt   DateTime @default(now())
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId, rangeEnd])
}

model ServerMemory {
  id         String                @id @default(cuid())
  guildId    String
  key        String
  value      String                @db.Text
  type       String
  source     String?
  createdBy  String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  expiresAt  DateTime?
  embedding  Unsupported("vector")?
  guild      Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, key])
  @@index([guildId, type])
}

model UserMemoryNote {
  id         String                @id @default(cuid())
  guildId    String
  userId     String
  key        String
  value      String                @db.Text
  source     String?
  createdBy  String?
  createdAt  DateTime              @default(now())
  expiresAt  DateTime?
  active     Boolean               @default(true)
  embedding  Unsupported("vector")?
  guild      Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user       User                  @relation("UserMemoryTarget", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId, key])
  @@index([guildId, userId, active])
}

model SearchCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  query        String
  responseJson Json
  provider     String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastAccessedAt DateTime @default(now())
}

model BotEventLog {
  id                  String   @id @default(cuid())
  guildId             String?
  channelId           String?
  messageId           String?
  userId              String?
  eventType           String
  intent              String?
  routeReason         String?
  modelUsed           String?
  usedSearch          Boolean  @default(false)
  toolCalls           Json?
  contextMessages     Int?
  memoryLayers        Json?
  latencyMs           Int?
  relationshipApplied Boolean  @default(false)
  debugTrace          Json?
  createdAt           DateTime @default(now())
  guild               Guild?   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([guildId, createdAt])
}

model InterjectionLog {
  id         String   @id @default(cuid())
  guildId    String
  channelId  String
  userId     String?
  topicKey   String?
  reason     String?
  confidence Float    @default(0)
  outcome    String
  createdAt  DateTime @default(now())
  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId, createdAt])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  scope     String
  scopeId   String
  key       String
  enabled   Boolean  @default(true)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, scopeId, key])
}

model ModeratorPreference {
  id                  String   @id @default(cuid())
  guildId             String
  moderatorUserId     String
  preferredStyle      String?
  forbiddenTopics     String[] @default([])
  forbiddenWords      String[] @default([])
  allowRoastTargets   String[] @default([])
  denyRoastTargets    String[] @default([])
  responseLengthOverride String?
  updatedAt           DateTime @updatedAt
  guild               Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, moderatorUserId])
}

model ChannelStats {
  id                     String   @id @default(cuid())
  guildId                String
  channelId              String
  totalMessages          Int      @default(0)
  totalMentions          Int      @default(0)
  avgMessageLength       Float    @default(0)
  activeHoursHistogram   Json?
  topUsersSnapshot       Json?
  conversationStarterCount Int    @default(0)
  updatedAt              DateTime @updatedAt
  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId])
}

model UserDailyAggregate {
  id                     String   @id @default(cuid())
  guildId                String
  userId                 String
  day                    DateTime
  messageCount           Int      @default(0)
  replyCount             Int      @default(0)
  mentionCount           Int      @default(0)
  charCount              Int      @default(0)
  conversationStarterCount Int    @default(0)
  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId, day])
}

model ChannelDailyAggregate {
  id                     String   @id @default(cuid())
  guildId                String
  channelId              String
  day                    DateTime
  messageCount           Int      @default(0)
  mentionCount           Int      @default(0)
  charCount              Int      @default(0)
  conversationStarterCount Int    @default(0)
  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId, day])
}
