generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guild {
  id                 String                @id
  name               String?
  botName            String                @default("Хори")
  preferredLanguage  String                @default("ru")
  roughnessLevel     Int                   @default(2)
  sarcasmLevel       Int                   @default(2)
  roastLevel         Int                   @default(2)
  interjectTendency  Int                   @default(1)
  replyLength        String                @default("short")
  preferredStyle     String                @default("коротко, сухо, по делу")
  forbiddenWords     String[]              @default([])
  forbiddenTopics    String[]              @default([])
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  channelConfigs     ChannelConfig[]
  userStats          UserStats[]
  userProfiles       UserProfile[]
  relationshipProfiles RelationshipProfile[]
  messages           Message[]
  channelSummaries   ChannelSummary[]
  serverMemories     ServerMemory[]
  userMemoryNotes    UserMemoryNote[]
  channelMemoryNotes ChannelMemoryNote[]
  eventMemories      EventMemory[]
  memoryBuildRuns    MemoryBuildRun[]
  botEventLogs       BotEventLog[]
  interjectionLogs   InterjectionLog[]
  moderatorPreferences ModeratorPreference[]
  channelStats       ChannelStats[]
  userDailyAggregates UserDailyAggregate[]
  channelDailyAggregates ChannelDailyAggregate[]
  topicSessions      TopicSession[]
  affinitySignals    AffinitySignal[]
  replyQueueItems    ReplyQueueItem[]
  memoryAlbumEntries MemoryAlbumEntry[]
  interactionRequests InteractionRequest[]
  reflectionLessons  ReflectionLesson[]
}

model ChannelConfig {
  id                String   @id @default(cuid())
  guildId           String
  channelId         String
  channelName       String?
  allowBotReplies   Boolean  @default(true)
  allowInterjections Boolean @default(false)
  isMuted           Boolean  @default(false)
  topicInterestTags String[] @default([])
  responseLengthOverride String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  guild             Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId])
  @@index([guildId])
}

model User {
  id               String                @id
  username         String?
  globalName       String?
  isBot            Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  messages         Message[]
  userStats        UserStats[]
  userProfiles     UserProfile[]
  relationshipTargets RelationshipProfile[] @relation("RelationshipTarget")
  relationshipUpdates RelationshipProfile[] @relation("RelationshipUpdatedBy")
  userMemoryNotes  UserMemoryNote[]      @relation("UserMemoryTarget")
  userDailyAggregates UserDailyAggregate[]
}

model UserStats {
  id                     String   @id @default(cuid())
  guildId                String
  userId                 String
  totalMessages          Int      @default(0)
  totalReplies           Int      @default(0)
  totalMentions          Int      @default(0)
  avgMessageLength       Float    @default(0)
  activeHoursHistogram   Json?
  topChannelsSnapshot    Json?
  conversationStarterCount Int    @default(0)
  updatedAt              DateTime @updatedAt
  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
}

model UserProfile {
  id               String   @id @default(cuid())
  userId           String
  guildId          String
  summaryShort     String
  styleTags        String[] @default([])
  topicTags        String[] @default([])
  confidenceScore  Float    @default(0)
  sourceWindowSize Int      @default(0)
  lastProfiledAt   DateTime?
  isEligible       Boolean  @default(false)
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
}

model RelationshipProfile {
  id               String   @id @default(cuid())
  userId           String
  guildId          String
  toneBias         String   @default("neutral")
  roastLevel       Int      @default(0)
  praiseBias       Int      @default(0)
  interruptPriority Int     @default(0)
  doNotMock        Boolean  @default(false)
  doNotInitiate    Boolean  @default(false)
  protectedTopics  String[] @default([])
  closeness        Float    @default(0.5)
  trustLevel       Float    @default(0.5)
  familiarity      Float    @default(0.5)
  interactionCount Int      @default(0)
  proactivityPreference Float @default(0.5)
  topicBoundaries  Json?
  updatedBy        String?
  updatedAt        DateTime @updatedAt
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user             User     @relation("RelationshipTarget", fields: [userId], references: [id], onDelete: Cascade)
  updatedByUser    User?    @relation("RelationshipUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([guildId, userId])
}

model Message {
  id               String    @id
  guildId          String
  channelId        String
  userId           String
  content          String    @db.Text
  createdAt        DateTime
  replyToMessageId String?
  mentionCount     Int       @default(0)
  charCount        Int       @default(0)
  tokenEstimate    Int       @default(0)
  flags            Json?
  threadId         String?
  vectorizedAt     DateTime?
  guild            Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyToMessage   Message?  @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          Message[] @relation("MessageReplies")
  embedding        MessageEmbedding?
  topicLinks       TopicMessageLink[]

  @@index([guildId, channelId, createdAt])
  @@index([guildId, userId, createdAt])
}

model MessageEmbedding {
  id         String                @id @default(cuid())
  messageId  String                @unique
  guildId    String
  channelId  String
  embedding  Unsupported("vector")?
  dimensions Int
  createdAt  DateTime              @default(now())
  message    Message               @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId])
}

model ChannelSummary {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  rangeStart  DateTime
  rangeEnd    DateTime
  summaryShort String
  summaryLong String   @db.Text
  topicTags   String[] @default([])
  notableUsers String[] @default([])
  createdAt   DateTime @default(now())
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId, rangeEnd])
}

model ServerMemory {
  id         String                @id @default(cuid())
  guildId    String
  key        String
  value      String                @db.Text
  type       String
  source     String?
  createdBy  String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  expiresAt  DateTime?
  embedding  Unsupported("vector")?
  dimensions Int?
  guild      Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, key])
  @@index([guildId, type])
  @@index([guildId, dimensions])
}

model UserMemoryNote {
  id         String                @id @default(cuid())
  guildId    String
  userId     String
  key        String
  value      String                @db.Text
  source     String?
  createdBy  String?
  createdAt  DateTime              @default(now())
  expiresAt  DateTime?
  active     Boolean               @default(true)
  embedding  Unsupported("vector")?
  dimensions Int?
  guild      Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user       User                  @relation("UserMemoryTarget", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId, key])
  @@index([guildId, userId, active])
  @@index([guildId, userId, active, dimensions])
}

model ChannelMemoryNote {
  id         String                @id @default(cuid())
  guildId    String
  channelId  String
  key        String
  value      String                @db.Text
  type       String                @default("note")
  tags       String[]              @default([])
  confidence Float                 @default(0.6)
  salience   Float                 @default(0.5)
  source     String?
  createdBy  String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  expiresAt  DateTime?
  active     Boolean               @default(true)
  embedding  Unsupported("vector")?
  dimensions Int?
  guild      Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId, key])
  @@index([guildId, channelId, active])
  @@index([guildId, channelId, type])
  @@index([guildId, channelId, active, dimensions])
}

model EventMemory {
  id         String                @id @default(cuid())
  guildId    String
  channelId  String?
  eventKey   String
  title      String?
  key        String
  value      String                @db.Text
  type       String                @default("event")
  tags       String[]              @default([])
  confidence Float                 @default(0.6)
  salience   Float                 @default(0.5)
  source     String?
  createdBy  String?
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  expiresAt  DateTime?
  active     Boolean               @default(true)
  embedding  Unsupported("vector")?
  dimensions Int?
  guild      Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, eventKey, key])
  @@index([guildId, active, updatedAt])
  @@index([guildId, channelId, active])
  @@index([guildId, eventKey])
  @@index([guildId, active, dimensions])
}

model SearchCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  query        String
  responseJson Json
  provider     String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastAccessedAt DateTime @default(now())
}

model BotEventLog {
  id                  String   @id @default(cuid())
  guildId             String?
  channelId           String?
  messageId           String?
  userId              String?
  eventType           String
  intent              String?
  routeReason         String?
  modelUsed           String?
  usedSearch          Boolean  @default(false)
  toolCalls           Json?
  contextMessages     Int?
  memoryLayers        Json?
  latencyMs           Int?
  promptTokens        Int?
  completionTokens    Int?
  totalTokens         Int?
  tokenSource         String?
  costUsd             Float?
  relationshipApplied Boolean  @default(false)
  debugTrace          Json?
  createdAt           DateTime @default(now())
  guild               Guild?   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([guildId, createdAt])
  @@index([guildId, totalTokens, createdAt])
}

model InterjectionLog {
  id         String   @id @default(cuid())
  guildId    String
  channelId  String
  userId     String?
  topicKey   String?
  reason     String?
  confidence Float    @default(0)
  outcome    String
  createdAt  DateTime @default(now())
  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId, createdAt])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  scope     String
  scopeId   String
  key       String
  enabled   Boolean  @default(true)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, scopeId, key])
}

model ModeratorPreference {
  id                  String   @id @default(cuid())
  guildId             String
  moderatorUserId     String
  preferredStyle      String?
  forbiddenTopics     String[] @default([])
  forbiddenWords      String[] @default([])
  allowRoastTargets   String[] @default([])
  denyRoastTargets    String[] @default([])
  responseLengthOverride String?
  updatedAt           DateTime @updatedAt
  guild               Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, moderatorUserId])
}

model ChannelStats {
  id                     String   @id @default(cuid())
  guildId                String
  channelId              String
  totalMessages          Int      @default(0)
  totalMentions          Int      @default(0)
  avgMessageLength       Float    @default(0)
  activeHoursHistogram   Json?
  topUsersSnapshot       Json?
  conversationStarterCount Int    @default(0)
  updatedAt              DateTime @updatedAt
  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId])
}

model UserDailyAggregate {
  id                     String   @id @default(cuid())
  guildId                String
  userId                 String
  day                    DateTime
  messageCount           Int      @default(0)
  replyCount             Int      @default(0)
  mentionCount           Int      @default(0)
  charCount              Int      @default(0)
  conversationStarterCount Int    @default(0)
  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId, day])
}

model ChannelDailyAggregate {
  id                     String   @id @default(cuid())
  guildId                String
  channelId              String
  day                    DateTime
  messageCount           Int      @default(0)
  mentionCount           Int      @default(0)
  charCount              Int      @default(0)
  conversationStarterCount Int    @default(0)
  guild                  Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId, day])
}

model RuntimeSetting {
  key       String   @id
  value     String   @db.Text
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemoryBuildRun {
  id             String   @id @default(cuid())
  guildId        String
  channelId      String?
  scope          String
  depth          String
  status         String   @default("queued")
  requestedBy    String
  bestModel      String?
  progressJson   Json?
  resultJson     Json?
  errorText      String?  @db.Text
  createdAt      DateTime @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  updatedAt      DateTime @updatedAt
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, status, createdAt])
  @@index([guildId, channelId, createdAt])
}

model PersonaConfig {
  id          String   @id @default(cuid())
  personaId   String   @unique
  version     Int      @default(1)
  displayName String
  language    String   @default("ru")
  configJson  Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

model MoodState {
  id           String   @id @default(cuid())
  scope        String
  scopeId      String
  mood         String
  intensity    Float    @default(0.5)
  isRareMode   Boolean  @default(false)
  startedAt    DateTime @default(now())
  endsAt       DateTime
  cooldownEnds DateTime?
  reasonJson   Json?
  updatedAt    DateTime @updatedAt

  @@index([scope, scopeId])
  @@index([endsAt])
}

model AffinitySignal {
  id         String   @id @default(cuid())
  guildId    String
  userId     String
  signalType String
  value      Float
  messageId  String?
  createdAt  DateTime @default(now())
  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId, createdAt])
  @@index([signalType, createdAt])
}

model TopicSession {
  id           String                 @id @default(cuid())
  guildId      String
  channelId    String
  title        String
  summaryShort String
  summaryFacts Json
  embedding    Unsupported("vector")?
  dimensions   Int?
  confidence   Float                  @default(0.5)
  startedAt    DateTime               @default(now())
  lastActiveAt DateTime               @default(now())
  closedAt     DateTime?
  closedReason String?
  guild        Guild                  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  messages     TopicMessageLink[]

  @@index([guildId, channelId, lastActiveAt])
  @@index([guildId, channelId, closedAt])
  @@index([guildId, channelId, dimensions])
}

model TopicMessageLink {
  id        String       @id @default(cuid())
  topicId   String
  messageId String
  relevance Float        @default(0.5)
  createdAt DateTime     @default(now())
  topic     TopicSession @relation(fields: [topicId], references: [id], onDelete: Cascade)
  message   Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([topicId, relevance])
  @@unique([topicId, messageId])
}

model ReplyQueueItem {
  id           String   @id @default(cuid())
  guildId      String
  channelId    String
  targetUserId String
  sourceMsgId  String
  priority     Int      @default(0)
  status       String   @default("queued")
  lockedUntil  DateTime?
  resultMsgId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  guild        Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, channelId, status, priority])
  @@index([lockedUntil])
}

model MediaMetadata {
  id              String   @id @default(cuid())
  mediaId         String   @unique
  type            String
  filePath        String
  toneTags        String[] @default([])
  triggerTags     String[] @default([])
  emotionTags     String[] @default([])
  messageKindTags String[] @default([])
  allowedMoods    String[] @default([])
  allowedChannels String[] @default([])
  nsfw            Boolean  @default(false)
  enabled         Boolean  @default(true)
  autoUseEnabled  Boolean  @default(true)
  manualOnly      Boolean  @default(false)
  weight          Int      @default(1)
  cooldownSec     Int      @default(600)
  minConfidence   Float    @default(0.82)
  minIntensity    Float    @default(0.62)
  lastUsedAt      DateTime?
  metaJson        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([nsfw])
  @@index([enabled])
}

model MediaUsageLog {
  id            String   @id @default(cuid())
  mediaId       String
  guildId       String
  channelId     String
  messageId     String?
  reasonKey     String?
  autoTriggered Boolean  @default(false)
  usedAt        DateTime @default(now())

  @@index([guildId, usedAt])
  @@index([guildId, autoTriggered, usedAt])
  @@index([guildId, mediaId, usedAt])
}

model MemoryAlbumEntry {
  id            String   @id @default(cuid())
  guildId       String
  channelId     String
  messageId     String?
  savedByUserId String
  authorUserId  String?
  content       String   @db.Text
  note          String?  @db.Text
  category      String   @default("moment")
  tags          String[] @default([])
  sourceUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, savedByUserId, messageId])
  @@index([guildId, savedByUserId, createdAt])
  @@index([guildId, channelId, createdAt])
}

model InteractionRequest {
  id                 String   @id @default(cuid())
  guildId            String
  channelId          String
  messageId          String?
  userId             String
  requestType        String
  status             String   @default("pending")
  title              String
  prompt             String   @db.Text
  category           String?
  expectedAnswerType String?
  allowedOptions     String[] @default([])
  answerText         String?  @db.Text
  answerJson         Json?
  metadataJson       Json?
  expiresAt          DateTime?
  answeredAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  guild              Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  events             InteractionRequestEvent[]

  @@index([guildId, status, createdAt])
  @@index([guildId, userId, status])
  @@index([expiresAt])
}

model InteractionRequestEvent {
  id            String   @id @default(cuid())
  requestId     String
  actorUserId   String?
  eventType     String
  fromStatus    String?
  toStatus      String
  payloadJson   Json?
  createdAt     DateTime @default(now())
  request       InteractionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model ReflectionLesson {
  id            String   @id @default(cuid())
  guildId       String
  channelId     String
  messageId     String?  @unique
  userId        String?
  lessonType    String   @default("feedback")
  sentiment     String   @default("neutral")
  severity      Int      @default(1)
  summary       String   @db.Text
  status        String   @default("open")
  metadataJson  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, status, createdAt])
  @@index([guildId, sentiment, createdAt])
}
