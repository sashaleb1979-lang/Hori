NODE_ENV=development
LOG_LEVEL=info

BOT_TOKEN=
BOT_ID=
# CSV Discord user IDs. Owner-only commands and /hori lockdown use this.
BOT_OWNERS=

BOT_NAME=Хори

# For Railway, prefer DATABASE_URL / REDIS_URL reference variables.
# Short aliases DB_URL / KV_URL also work.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hori
REDIS_URL=redis://localhost:6379
AI_PROVIDER=router
BRAVE_KEY=

# Primary default chat tier in router mode.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Final paid fallback and embeddings.
OAI_KEY=
OPENAI_MODEL=gpt-5-nano
OAI_EMBED=text-embedding-3-small

# Free/limited providers before OpenAI.
GOOGLE_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/zai-org/glm-4.7-flash

GITHUB_TOKEN=
GITHUB_MODELS_URL=https://models.github.ai/inference/chat/completions
GITHUB_MODEL_PRIMARY=openai/gpt-5-mini
GITHUB_MODEL_SECONDARY=openai/gpt-5-chat
GITHUB_MODEL_TERTIARY=openai/gpt-5-nano

AI_ROUTER_ENABLE_DEEPSEEK=true
AI_ROUTER_ENABLE_GEMINI=true
AI_ROUTER_ENABLE_CLOUDFLARE=true
AI_ROUTER_ENABLE_GITHUB=true
AI_ROUTER_ENABLE_OPENAI=true
AI_ROUTER_LOG_VERBOSE=true
AI_ROUTER_USE_GEMINI_PRO_FOR_COMPLEX=true
AI_ROUTER_DEEPSEEK_COOLDOWN_MS=300000
AI_ROUTER_GEMINI_FLASH_DAILY_LIMIT=250
AI_ROUTER_GEMINI_PRO_DAILY_LIMIT=100
AI_ROUTER_CLOUDFLARE_COOLDOWN_MS=900000
AI_ROUTER_GITHUB_COOLDOWN_MS=1800000
AI_ROUTER_OPENAI_COOLDOWN_MS=300000

# Optional direct OpenAI-only mode:
# AI_PROVIDER=openai
# OAI_CHAT=gpt-5.4-nano
# OAI_SMART=gpt-5.4-nano
# OAI_EMBED=text-embedding-3-small

# Optional overrides. Defaults already cover the rest.
# BOT_LANG=ru
# HOST=0.0.0.0
# PORT=3000
# ADMIN_KEY=change-me
# AI_TIMEOUT=240000
# FEATURE_MEMORY_ALBUM_ENABLED=true
# FEATURE_INTERACTION_REQUESTS_ENABLED=true
# FEATURE_LINK_UNDERSTANDING_ENABLED=true
# FEATURE_NATURAL_MESSAGE_SPLITTING_ENABLED=true
# FEATURE_SELECTIVE_ENGAGEMENT_ENABLED=true
# FEATURE_SELF_REFLECTION_LESSONS_ENABLED=true
# DISCORD_REGISTER_LEGACY_COMMANDS=false
# NATURAL_SPLIT_CHANCE=0.06
# NATURAL_SPLIT_COOLDOWN_SEC=1800
# SELECTIVE_ENGAGEMENT_MIN_SCORE=0.68

# Optional compact JSON for advanced tuning:
# CFG={"features":{"webSearch":true,"autoInterject":false,"linkUnderstandingEnabled":true},"profiles":{"minMessages":50},"search":{"maxRequests":2,"maxPages":3},"chat":{"naturalSplitChance":0.06}}
