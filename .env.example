NODE_ENV=development
LOG_LEVEL=info

BOT_TOKEN=
BOT_ID=
# CSV Discord user IDs. Owner-only commands and /hori lockdown use this.
BOT_OWNERS=

BOT_NAME=Хори

# For Railway, prefer DATABASE_URL / REDIS_URL reference variables.
# Short aliases DB_URL / KV_URL also work.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hori
REDIS_URL=redis://localhost:6379
AI_URL=http://localhost:11434
BRAVE_KEY=

# Optional overrides. Defaults already cover the rest.
# BOT_LANG=ru
# HOST=0.0.0.0
# PORT=3000
# ADMIN_KEY=change-me
# AI_FAST=qwen3.5:9b
# AI_SMART=qwen3.5:9b
# AI_EMBED=nomic-embed-text
# AI_TIMEOUT=240000
# FEATURE_MEMORY_ALBUM_ENABLED=true
# FEATURE_INTERACTION_REQUESTS_ENABLED=true
# FEATURE_LINK_UNDERSTANDING_ENABLED=true
# FEATURE_NATURAL_MESSAGE_SPLITTING_ENABLED=true
# FEATURE_SELECTIVE_ENGAGEMENT_ENABLED=true
# FEATURE_SELF_REFLECTION_LESSONS_ENABLED=true
# DISCORD_REGISTER_LEGACY_COMMANDS=false
# NATURAL_SPLIT_CHANCE=0.06
# NATURAL_SPLIT_COOLDOWN_SEC=1800
# SELECTIVE_ENGAGEMENT_MIN_SCORE=0.68

# Optional compact JSON for advanced tuning:
# CFG={"features":{"webSearch":true,"autoInterject":false,"linkUnderstandingEnabled":true},"profiles":{"minMessages":50},"search":{"maxRequests":2,"maxPages":3},"chat":{"naturalSplitChance":0.06}}
