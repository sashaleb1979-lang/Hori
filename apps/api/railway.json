{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/Dockerfile",
    "watchPatterns": [
      "/apps/api/**",
      "/packages/analytics/**",
      "/packages/config/**",
      "/packages/core/**",
      "/packages/memory/**",
      "/packages/shared/**",
      "/prisma/**",
      "/scripts/**",
      "/Dockerfile",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/railway.json",
      "/tsconfig.json",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health/ready",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node scripts/start.mjs"
  }
}